# BidSpace environment variables.
# Secrets are managed in Doppler — pull with: doppler run -- <command>
# This file documents variable NAMES only. Never commit real values.
# For local Next.js runtime, copy the web-facing variables into
# `apps/web/.env.local`, or inject them via Doppler when running `pnpm --filter
# @bidspace/web dev`.
# For Supabase CLI/psql tooling, export `DATABASE_URL` in your shell before
# running database commands from the repo root.

# --- Database / Storage (Supabase Postgres + PostGIS) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Auth (Clerk) ---
CLERK_PUBLISHABLE_KEY=
# Optional Clerk alias accepted by `apps/web/lib/env.ts` for local web runtime.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# --- Payments (Stripe Connect) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_CLIENT_ID=

# --- Maps (Mapbox) ---
MAPBOX_ACCESS_TOKEN=
NEXT_PUBLIC_MAPBOX_TOKEN=

# --- Media (Cloudinary) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Product analytics (PostHog) ---
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- Error monitoring (Sentry) ---
SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# --- AI / intelligence layer ---
OPENAI_API_KEY=
