# BidSpace — environment variable manifest (NAMES ONLY, NO VALUES)
#
# Source of truth for VALUES is Doppler (cross-app locked secrets manager).
# Pull locally with the Doppler CLI; never paste real secrets here or commit a real .env.
#   doppler run -- <command>
#
# .env* is git-ignored. This .env.example is the ONLY env file in the repo.
#
# CROSS-APP PROVIDER LOCK (2026-06-04): Auth = Clerk, Maps = Mapbox across all three apps
# (Explore&Earn / BidSpace / Sweepza).
#
# Variable order follows the AutomatedEmpires canonical integration spine so all three
# apps read top-to-bottom the same way.

# --- Doppler (secrets) ---
DOPPLER_TOKEN=

# --- Supabase (database / storage — Postgres + PostGIS for spatial; auth is Clerk) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Clerk (AUTH — cross-app standard, locked 2026-06-04) ---
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# --- Stripe (payments — Connect for marketplace) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_CLIENT_ID=

# --- Vercel (hosting) ---
VERCEL_TOKEN=

# --- Cloudinary (public image delivery) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- PostHog (product analytics) ---
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- Sentry (error monitoring) ---
SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# --- Resend (transactional email) ---
RESEND_API_KEY=

# --- Mapbox (MAPS — cross-app standard, locked 2026-06-04) ---
MAPBOX_ACCESS_TOKEN=
NEXT_PUBLIC_MAPBOX_TOKEN=

# --- GitHub (agent + CI automation) ---
GITHUB_TOKEN=

# --- CLAOS cloud-agent dispatch (set in CI / Doppler, not local) ---
COPILOT_CLOUD_TOKEN=

# --- AI / intelligence layer (optional workers) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
